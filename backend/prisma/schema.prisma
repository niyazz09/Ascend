datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  goals          LearningGoal[]
  masteries      Mastery[]
  evidenceLogs   EvidenceLog[]
  recommendation Recommendation?
}

model LearningGoal {
  id        String   @id @default(uuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap   Roadmap?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Roadmap {
  id                 String        @id @default(uuid())
  goalId             String        @unique
  goal               LearningGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  progressPercentage Float         @default(0.0)
  source             String        @default("generated") // "generated" | "fallback"
  nodes              RoadmapNode[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model RoadmapNode {
  id            String   @id @default(uuid())
  roadmapId     String
  roadmap       Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  topicId       String
  title         String
  status        String   // "completed", "next", "locked"
  prerequisites String[] // Native PostgreSQL string array
  resources     Json?    // Nullable field to store JSON list of recommended resources
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([roadmapId, topicId])
  @@index([roadmapId])
}

model Mastery {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId      String
  score        Float         @default(0.0)
  updatedAt    DateTime      @updatedAt
  evidenceLogs EvidenceLog[]

  @@unique([userId, topicId])
  @@index([userId])
}

model EvidenceLog {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  masteryId     String
  mastery       Mastery  @relation(fields: [masteryId], references: [id], onDelete: Cascade)
  topicId       String
  difficulty    Float
  correct       Boolean
  questionType  String
  delta         Float
  previousScore Float
  newScore      Float
  timestamp     DateTime @default(now())

  @@index([userId])
  @@index([masteryId])
  @@index([topicId])
}

model Recommendation {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nextTopic    String?
  reviewTopics String[]
  focusAreas   String[]
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model LessonCache {
  id               String   @id @default(uuid())
  topicId          String   @unique
  goal             String
  lessonVersion    Int      @default(1)
  promptVersion    Int      @default(1)
  retrieverVersion Int      @default(1)
  confidenceScore  Float
  isGrounded       Boolean  @default(true)
  lessonContent    Json
  sources          Json
  videos           Json
  metadata         Json
  cachedAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ReflectionLog {
  id          String   @id @default(uuid())
  userId      String
  topicId     String
  reflection  String
  aiInsight   String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model LearningProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  preferences Json?    // { pace: "Normal", style: "Visual" }
  analytics   Json?    // { velocity: 2.5, quizAverage: 85, streak: 3 }
  mastery     Json?    // { [topicId]: score }
  career      Json?    // { goal: "Frontend Developer", weakConcepts: [] }
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model TelemetryLog {
  id              String   @id @default(uuid())
  action          String
  latencyMs       Int
  cacheHit        Boolean  @default(false)
  provider        String
  citationCount   Int      @default(0)
  confidenceScore Float?
  timestamp       DateTime @default(now())
}

